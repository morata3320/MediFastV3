{
  "name": "medifast-backend",
  "version": "1.0.0",
  "description": "Backend MVC para MediFast Reto 2",
  "type": "module",
  "main": "controlador/server.js",
  "scripts": {
    "start": "node controlador/server.js",
    "dev": "node controlador/server.js",
    "prisma:generate": "prisma generate --schema=modelo/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=modelo/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=modelo/prisma/schema.prisma",
    "seed": "node modelo/prisma/seed.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "lint": "eslint ."
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "eslint": "^9.39.1",
    "globals": "^15.15.0",
    "jest": "^29.7.0",
    "prisma": "^6.19.0",
    "supertest": "^7.0.0"
  }
}
